{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "outback-website-alpha",
  "compatibility_date": "2026-04-02",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "node ./scripts/prepare-assets.mjs"
  },
  "assets": {
    "directory": "./public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}

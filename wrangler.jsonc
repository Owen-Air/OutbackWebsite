{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "outback-website-alpha",
  "compatibility_date": "2026-04-02",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      ".git/**",
      "Videos/**"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
